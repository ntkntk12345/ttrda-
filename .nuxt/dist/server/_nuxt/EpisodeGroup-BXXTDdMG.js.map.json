{"file":"EpisodeGroup-BXXTDdMG.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAKA,UAAM,QAAQ;AA+Bd,UAAM,oBAAoB,IAAI,CAAC;AAE/B;AAAA,MACE,MAAM,CAAC,MAAM,iBAAiB,MAAM,eAAe,MAAM,QAAQ;AAAA,MACjE,MAAM;AACJ,YAAI,OAAO,MAAM,oBAAoB,UAAU;AAC7C,4BAAkB,QAAQ,MAAM;AAChC;AAAA,QACF;AAEA,cAAM,eAAe,MAAM,SAAS;AAAA,UAClC,CAAC,WAAW,OAAO,gBAAgB,MAAM;AAAA,QAAA;AAE3C,0BAAkB,QAAQ,gBAAgB,IAAI,eAAe;AAAA,MAC/D;AAAA,MACA,EAAE,WAAW,MAAM,MAAM,KAAA;AAAA,IAAK;AAGhC,UAAM,eAAe,SAAS,MAAM;AAClC,UAAI,OAAO,MAAM,oBAAoB,UAAU;AAC7C,eAAO,MAAM;AAAA,MACf;AAEA,aAAO,kBAAkB;AAAA,IAC3B,CAAC;AAED,UAAM,mBAAmB,SAAS,MAAM,MAAM,SAAS,aAAa,KAAK,CAAC;AAU1E,aAAS,eAAe,SAAkB;AACxC,YAAM,aAAa,iBAAiB,OAAO,eAAe;AAC1D,YAAM,SAAS,IAAI,gBAAA;AACnB,aAAO,IAAI,OAAO,QAAQ,IAAI;AAC9B,aAAO,IAAI,UAAU,UAAU;AAC/B,aAAO,UAAU,MAAM,SAAS,IAAI,OAAO,UAAU;AAAA,IACvD;;;AAKU,UAAA,QAAA,SAAS,QAAM;AACrB,cAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,uDAAmD,MAAA,CAAA,CAAA,iMAAA;sBAS3B,QAAA,UAAQ,CAA1B,QAAQ,UAAK;;aAEFC,QAAAA,OAAAA,KAAAA,KAAAA,MAAAA,EAAAA;AAAAA;cAAuFC,MAAA,YAAA,MAAiB;;8BAWxHC,eAAA,OAAO,WAAW;;;YAKjBD,MAAA,gBAAA,GAAgB;;wBAGMA,MAAA,gBAAA,EAAiB,aAAW,CAAvC,YAAO;;gBAEd,QAAA,aAAW;;iBACID,QAAAA,OAAAA,KAAAA,KAAAA,MAAAA,EAAAA;AAAAA;kBAAwG,QAAA,mBAAmB,QAAQ;;kCAWrJE,eAAA,QAAQ,IAAI;;;gBAId,QAAoBF,QAAAA,OAAAA,KAAAA,KAAAA,MAAAA,EAAAA;AAAAA;kBAAwG,QAAA,mBAAmB,QAAQ;;gBAQvJ,IAAI,eAAe,OAAO;AAAA,cAAA;iCAV7B,CAaW,GAAAG,QAAAC,UAAA,aAAA;;AADND,2BAAA,GAAAD,eAAA,QAAQ,IAAI,CAAA,EAAA;AAAA;;sBAAZG,gBAAAC,gBAAA,QAAQ,IAAI,GAAA,CAAA;AAAA,oBAAA;AAAA;;;;;;;;;;;;;AAQrB,cAAA,OAAAR,eAAAC,WAAA,EAAA,OAAM,6EAAyE,MAAA,CAAA,CAAA,iCAAA;AAAA;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","cn","_unref","_ssrInterpolate","_push","_parent","_createTextVNode","_toDisplayString"],"sources":["../../../../src/components/features/EpisodeGroup.vue"],"sourcesContent":["<script setup lang=\"ts\">\nimport type { PropType } from \"vue\";\n\nimport type { Episode, EpisodeServer } from \"~/types/ophim\";\n\nconst props = defineProps({\n  episodes: {\n    type: Array as PropType<EpisodeServer[]>,\n    default: () => [],\n  },\n  currentEpisode: {\n    type: String,\n    default: \"\",\n  },\n  currentServer: {\n    type: String,\n    default: \"\",\n  },\n  activeServerIdx: {\n    type: Number,\n    default: undefined,\n  },\n  movieSlug: {\n    type: String,\n    default: \"\",\n  },\n  interactive: {\n    type: Boolean,\n    default: false,\n  },\n});\n\nconst emit = defineEmits<{\n  select: [payload: { episode: Episode; serverIdx: number }];\n}>();\n\nconst localActiveServer = ref(0);\n\nwatch(\n  () => [props.activeServerIdx, props.currentServer, props.episodes],\n  () => {\n    if (typeof props.activeServerIdx === \"number\") {\n      localActiveServer.value = props.activeServerIdx;\n      return;\n    }\n\n    const matchedIndex = props.episodes.findIndex(\n      (server) => server.server_name === props.currentServer,\n    );\n    localActiveServer.value = matchedIndex >= 0 ? matchedIndex : 0;\n  },\n  { immediate: true, deep: true },\n);\n\nconst activeServer = computed(() => {\n  if (typeof props.activeServerIdx === \"number\") {\n    return props.activeServerIdx;\n  }\n\n  return localActiveServer.value;\n});\n\nconst activeServerData = computed(() => props.episodes[activeServer.value]);\n\nfunction handleEpisodeClick(episode: Episode) {\n  if (!props.interactive) {\n    return;\n  }\n\n  emit(\"select\", { episode, serverIdx: activeServer.value });\n}\n\nfunction buildWatchLink(episode: Episode) {\n  const serverName = activeServerData.value?.server_name || \"\";\n  const params = new URLSearchParams();\n  params.set(\"tap\", episode.slug);\n  params.set(\"server\", serverName);\n  return `/watch/${props.movieSlug}?${params.toString()}`;\n}\n</script>\n\n<template>\n  <div\n    v-if=\"episodes.length\"\n    class=\"rounded-xl border border-white/5 bg-card-dark p-6\"\n  >\n    <h3 class=\"mb-4 flex items-center gap-2 text-xl font-bold text-white\">\n      <span class=\"h-6 w-1 rounded-full bg-primary\" />\n      Danh sách tập\n    </h3>\n\n    <div class=\"mb-6 flex flex-wrap gap-2\">\n      <button\n        v-for=\"(server, index) in episodes\"\n        :key=\"server.server_name\"\n        :class=\"\n          cn(\n            'rounded-lg px-4 py-2 text-sm font-medium transition-all',\n            activeServer === index\n              ? 'bg-primary text-slate-950 shadow-lg shadow-primary/20'\n              : 'bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white',\n          )\n        \"\n        type=\"button\"\n        @click=\"localActiveServer = index\"\n      >\n        {{ server.server_name }}\n      </button>\n    </div>\n\n    <div\n      v-if=\"activeServerData\"\n      class=\"grid max-h-60 grid-cols-3 gap-2 overflow-y-auto pr-2 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8\"\n    >\n      <template v-for=\"episode in activeServerData.server_data\" :key=\"episode.slug\">\n        <button\n          v-if=\"interactive\"\n          :class=\"\n            cn(\n              'rounded border py-2 text-center text-xs font-semibold transition-all',\n              currentEpisode === episode.slug\n                ? 'border-cyan-400 bg-cyan-400 text-black shadow-lg shadow-cyan-400/20'\n                : 'border-white/10 bg-transparent text-gray-300 hover:border-cyan-400/50 hover:text-cyan-400',\n            )\n          \"\n          type=\"button\"\n          @click=\"handleEpisodeClick(episode)\"\n        >\n          {{ episode.name }}\n        </button>\n        <NuxtLink\n          v-else\n          :class=\"\n            cn(\n              'rounded border py-2 text-center text-xs font-semibold transition-all',\n              currentEpisode === episode.slug\n                ? 'border-cyan-400 bg-cyan-400 text-black shadow-lg shadow-cyan-400/20'\n                : 'border-white/10 bg-transparent text-gray-300 hover:border-cyan-400/50 hover:text-cyan-400',\n            )\n          \"\n          :to=\"buildWatchLink(episode)\"\n        >\n          {{ episode.name }}\n        </NuxtLink>\n      </template>\n    </div>\n  </div>\n\n  <div\n    v-else\n    class=\"rounded-xl border border-white/5 bg-card-dark p-6 text-sm text-gray-400\"\n  >\n    Không có tập phim nào.\n  </div>\n</template>\n"],"version":3}